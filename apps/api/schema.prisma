datasource sqlite {
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  provider          = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                              String                  @id @default(cuid())
  email                           String                  @unique @default("")
  fullName                        String                  @default("")
  phone                           String                  @default("")
  password                        String                  @default("")
  mustChangePassword              Boolean                 @default(false)
  onboardingCompleted             Boolean                 @default(true)
  firstTimePasswordToken          String                  @default("")
  firstTimePasswordTokenExpiresAt DateTime?
  welcomeEmailSentAt              DateTime?
  role                            String                  @default("tenant")
  status                          String                  @default("active")
  propertiesOwned                 Property[]              @relation("Property_landlord")
  memberships                     Membership[]            @relation("Membership_user")
  uploadedAssets                  UploadedAsset[]         @relation("UploadedAsset_landlord")
  syncEvents                      SyncEvent[]             @relation("SyncEvent_actor")
  updatedSyncPolicies             SyncPolicy[]            @relation("SyncPolicy_updatedByUser")
  publicListings                  PublicPropertyListing[] @relation("PublicPropertyListing_landlord")
  rentalInquiries                 RentalInquiry[]         @relation("RentalInquiry_landlord")
  createdAt                       DateTime?               @default(now())
  updatedAt                       DateTime?               @updatedAt
}

model Property {
  id             String                @id @default(cuid())
  landlord       User?                 @relation("Property_landlord", fields: [landlordId], references: [id])
  landlordId     String?               @map("landlord")
  name           String                @default("")
  address        String                @default("")
  unitCode       String                @default("")
  subscription   PropertySubscription? @relation("Property_subscription", fields: [subscriptionId], references: [id])
  subscriptionId String?               @unique @map("subscription")
  memberships    Membership[]          @relation("Membership_property")
  uploadedAssets UploadedAsset[]       @relation("UploadedAsset_property")
  syncEvents     SyncEvent[]           @relation("SyncEvent_property")
  createdAt      DateTime?             @default(now())
  updatedAt      DateTime?             @updatedAt

  @@index([landlordId])
}

model Membership {
  id         String    @id @default(cuid())
  user       User?     @relation("Membership_user", fields: [userId], references: [id])
  userId     String?   @map("user")
  property   Property? @relation("Membership_property", fields: [propertyId], references: [id])
  propertyId String?   @map("property")
  role       String    @default("tenant")
  status     String    @default("active")
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@index([userId])
  @@index([propertyId])
}

model PropertySubscription {
  id                 String    @id @default(cuid())
  property           Property? @relation("Property_subscription")
  tier               String    @default("free")
  subscriptionStatus String    @default("trial")
  trialEndsAt        DateTime?
  createdAt          DateTime? @default(now())
  updatedAt          DateTime? @updatedAt
}

model UploadedAsset {
  id           String    @id @default(cuid())
  landlord     User?     @relation("UploadedAsset_landlord", fields: [landlordId], references: [id])
  landlordId   String?   @map("landlord")
  property     Property? @relation("UploadedAsset_property", fields: [propertyId], references: [id])
  propertyId   String?   @map("property")
  category     String    @default("")
  secureUrl    String    @default("")
  publicId     String    @default("")
  bytes        Int?
  format       String    @default("")
  resourceType String    @default("")
  createdAt    DateTime? @default(now())
  updatedAt    DateTime? @updatedAt

  @@index([landlordId])
  @@index([propertyId])
}

model SyncEvent {
  id                   String    @id @default(cuid())
  property             Property? @relation("SyncEvent_property", fields: [propertyId], references: [id])
  propertyId           String?   @map("property")
  actor                User?     @relation("SyncEvent_actor", fields: [actorId], references: [id])
  actorId              String?   @map("actor")
  kind                 String
  clientSessionId      String    @default("")
  clientStorageVersion String    @default("")
  counts               String?
  status               String    @default("ok")
  errorMessage         String    @default("")
  createdAt            DateTime? @default(now())
  updatedAt            DateTime? @updatedAt

  @@index([propertyId])
  @@index([actorId])
}

model SyncPolicy {
  id                      String    @id @default(cuid())
  role                    String    @unique
  enabled                 Boolean   @default(true)
  mode                    String    @default("after_change")
  delayAfterChangeSeconds Int?      @default(60)
  intervalSeconds         Int?      @default(300)
  retryBackoffSeconds     Int?      @default(60)
  maxRetryBackoffSeconds  Int?      @default(300)
  maxJitterSeconds        Int?      @default(0)
  initialHydrationOnLogin Boolean   @default(true)
  forceSyncOnLogin        Boolean   @default(false)
  devShowCountdown        Boolean   @default(true)
  updatedByUser           User?     @relation("SyncPolicy_updatedByUser", fields: [updatedByUserId], references: [id])
  updatedByUserId         String?   @map("updatedByUser")
  createdAt               DateTime? @default(now())
  updatedAt               DateTime? @updatedAt

  @@index([updatedByUserId])
}

model PublicPropertyListing {
  id               String                  @id @default(cuid())
  landlord         User?                   @relation("PublicPropertyListing_landlord", fields: [landlordId], references: [id])
  landlordId       String?                 @map("landlord")
  sourcePropertyId String                  @unique @default("")
  slug             String                  @unique @default("")
  propertyName     String                  @default("")
  address          String                  @default("")
  unitCode         String                  @default("")
  headline         String                  @default("")
  description      String                  @default("")
  monthlyRentCents Int?                    @default(0)
  currency         String                  @default("USD")
  bedrooms         Int?                    @default(0)
  bathrooms        Int?                    @default(0)
  areaSqm          Int?                    @default(0)
  isAvailable      Boolean                 @default(false)
  isOffered        Boolean                 @default(false)
  photos           String?
  relatedListings  PublicPropertyListing[] @relation("PublicPropertyListing_relatedFrom")
  relatedFrom      PublicPropertyListing[] @relation("PublicPropertyListing_relatedFrom")
  inquiries        RentalInquiry[]         @relation("RentalInquiry_listing")
  createdAt        DateTime?               @default(now())
  updatedAt        DateTime?               @updatedAt

  @@index([landlordId])
}

model RentalInquiry {
  id             String                 @id @default(cuid())
  listing        PublicPropertyListing? @relation("RentalInquiry_listing", fields: [listingId], references: [id])
  listingId      String?                @map("listing")
  landlord       User?                  @relation("RentalInquiry_landlord", fields: [landlordId], references: [id])
  landlordId     String?                @map("landlord")
  requesterName  String                 @default("")
  requesterEmail String                 @default("")
  requesterPhone String                 @default("")
  message        String                 @default("")
  status         String                 @default("new")
  createdAt      DateTime?              @default(now())
  updatedAt      DateTime?              @updatedAt

  @@index([listingId])
  @@index([landlordId])
}
